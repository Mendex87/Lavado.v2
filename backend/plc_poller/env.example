# Configuración sugerida para correr plc_poller en la PC del taller
# Ajustar según PLC real y dirección Tailscale de la VPS

PLC_HOST=192.168.0.10
PLC_RACK=0
PLC_SLOT=1
BACKEND_URL=http://nombre-vps.tailnet.ts.net:8010/api/v1
PLC_MAPPING_PATH=plc_poller/mapping.example.json
PLC_POLL_INTERVAL_SECONDS=0.1
